# =============================================================================
# API 키 설정 방법
# -----------------------------------------------------------------------------
# 1) 이 파일을 복사해 프로젝트 루트에 `.env.local` 이라는 이름으로 저장합니다.
# 2) 아래 각 항목에 본인의 키 값을 입력합니다.
# 3) `.env.local`은 Git에 커밋되지 않습니다. 실제 키는 여기에만 두세요.
# =============================================================================

# 네이버 개발자센터(https://developers.naver.com) 애플리케이션에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OpenAI API 키(https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# 선택: 사용할 모델 (기본 gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
